# Variables para modo mock — sin AWS, todo local
# Este archivo SÍ va al repo (no tiene secretos reales)
# Uso: npm run dev:mock

AWS_COGNITO_REGION=us-east-1
AWS_USER_POOLS_ID=us-east-1_mock
AWS_COGNITO_HOSTED_UI_DOMAIN=http://localhost:8080/mock-cognito
AWS_CLIENT_ID_TYCSPORTS=mock-client-tycsports
AWS_CLIENT_ID_PLAY=mock-client-play
REDIRECT_BASE_LOCAL=http://localhost:8080
REDIRECT_BASE_PROD=https://auth.tycsports.com
