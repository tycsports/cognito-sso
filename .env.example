# ─────────────────────────────────────────────
# Cognito SSO — variables de entorno
# Copiá este archivo a .env y completá los valores
# ─────────────────────────────────────────────

# User Pool
AWS_COGNITO_REGION=us-east-1
AWS_USER_POOLS_ID=us-east-1_XXXXXXXXX

# Hosted UI domain (Cognito → App integration → Domain)
# Sin https:// — solo el dominio
# Ej: tycsports.auth.us-east-1.amazoncognito.com
# Ej prod (custom domain): auth.tycsports.com
AWS_COGNITO_HOSTED_UI_DOMAIN=TBD.auth.us-east-1.amazoncognito.com

# App Clients (Cognito → App integration → App clients)
# Un client ID por sitio
AWS_CLIENT_ID_TYCSPORTS=
AWS_CLIENT_ID_PLAY=

# Scopes OAuth (default: openid email profile)
# OAUTH_SCOPES=openid email profile

# URLs base por entorno
REDIRECT_BASE_LOCAL=http://localhost:8080
REDIRECT_BASE_PROD=https://auth.tycsports.com
